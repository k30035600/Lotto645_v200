# ============================================================
# 선택 사항: 이 파일을 .env 로 복사 후 실제 값으로 설정
# ============================================================

# 당첨번호는 동행복권 결과 페이지 파싱으로 취득합니다. (API 미사용)

# --- 동행복권 접속 제한 우회 ---
# USE_PLAYWRIGHT=1          # 1=Playwright+Stealth 시도(기본), 0=urllib만
# DHLOTTERY_COOKIE=         # (선택) 브라우저에서 복사한 쿠키

# 동행복권 로그인 (선택) - 설정 시 Playwright로 로그인 후 결과 페이지 파싱
# .env 에만 저장하고 Git에 커밋하지 마세요.
# DHLOTTERY_USER=           # 동행복권 아이디
# DHLOTTERY_PASSWORD=       # 동행복권 비밀번호

# Residential Proxy (주거용 IP) - 클라우드(AWS/GCP 등) IP 차단 시 사용. 한국 주거용 IP 강력 추천.
# DHLOTTERY_PROXY=http://kr.residential-proxy.com:8080
# DHLOTTERY_PROXY=http://user:pass@proxy.example.com:8080
# DHLOTTERY_PROXY_USER=    # (선택) 인증 아이디
# DHLOTTERY_PROXY_PASS=    # (선택) 인증 비밀번호

# --- Google Gemini AI 설정 (필수) ---
# AI 분석 기능 사용을 위해 필요합니다.
# https://aistudio.google.com/app/apikey 에서 발급 가능
GEMINI_API_KEY=your_gemini_api_key_here
